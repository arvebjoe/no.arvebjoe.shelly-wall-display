{
  "title": {
    "en": "light-level-complete"
  },
  "titleFormatted": {
    "en": "Set light level [[strength]] on slider [[name]] as completed on the display"
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=display"
    },
    {
      "type": "text",
      "name": "name",
      "required": false,
      "title": {
        "en": "Slider name"
      },
      "placeholder": {
        "en": "Slider name (empty = all sliders)"
      }
    },
    {
      "type": "number",
      "name": "strength",
      "title": {
        "en": "Strength"
      },
      "placeholder": {
        "en": "The light level strength"
      },
      "min": 0,
      "max": 1,
      "step": 0.01
    }
  ]
}